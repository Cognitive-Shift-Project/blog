{
  "name": "cognitive-shift-project",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=v24.14.0"
  },
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "astro dev --port 4322",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "preflight": "pnpm typecheck && astro build",
    "deploy:worker": "pnpm build && cross-env WRANGLER_SEND_METRICS=false wrangler deploy",
    "typegen": "wrangler types",
    "typecheck": "pnpm typegen && tsc --project tsconfig.json --noEmit --pretty && astro check",
    "check": "biome check && prettier --check \"**/*.astro\" && astro check",
    "check:fix": "biome check --write && prettier --write \"**/*.astro\" && astro check"
  },
  "overrides": {
    "vite": "^7"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.0",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@lucide/astro": "^1.14.0",
    "@tailwindcss/vite": "^4.2.3",
    "astro": "^6.3.1",
    "cf-workers-og": "^3.0.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.3",
    "unist-util-visit": "^5.1.0",
    "wrangler": "^4.84.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.4.12",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "cross-env": "^10.1.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "react": "^19.2.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
