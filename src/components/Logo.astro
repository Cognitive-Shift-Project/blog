---
import type { HTMLAttributes } from 'astro/types'
import { cn } from '@/lib/style'

/**
 * Cognitive Shift Project mark: outer ring with two interlocking oval lobes.
 * Sizes via CSS `h-` class; colors via `currentColor`.
 */
interface Props extends Pick<HTMLAttributes<'svg'>, 'class'> {
	color?: string
	widthPx?: number
	logoHeightPx?: number
}

const { class: className } = Astro.props as Props
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 64 64"
	fill="none"
	stroke="currentColor"
	stroke-width="1.5"
	class={cn('h-6 w-auto', className)}
>
	<title>Cognitive Shift Project</title>
	<circle cx="32" cy="32" r="29"></circle>
	<ellipse cx="24" cy="22" rx="17" ry="10" transform="rotate(-40 24 22)"></ellipse>
	<ellipse cx="40" cy="42" rx="17" ry="10" transform="rotate(-40 40 42)"></ellipse>
</svg>
