---
import FormattedDate from '@/components/FormattedDate.astro'
import Badge from '@/components/ui/Badge.astro'
import { cn } from '@/lib/style'
import { getBlogPostHref, getReadTimeMinutes, getTagHref, type BlogPost } from '@/lib/blog'

type Props = {
	post: BlogPost
	compact?: boolean
	showTags?: boolean
}

const { post, compact = false, showTags = true } = Astro.props as Props
const { title, description, publishedAt, tags, thumbnail, thumbnailAlt } = post.data
---

<article class={cn('blog-post-preview', compact && 'blog-post-preview--compact')}>
	{
		thumbnail && (
			<a
				href={getBlogPostHref(post)}
				class="blog-post-preview-image-link"
				data-link-affordance="false"
				aria-label={`Read ${title}`}
			>
				<img class="blog-post-preview-image" src={thumbnail} alt={thumbnailAlt ?? ''} loading="lazy" />
			</a>
		)
	}
	<div class="min-w-0">
		<a href={getBlogPostHref(post)} class="post-title-link group block" data-link-affordance="false">
			<h3 class={compact ? 'fluid-title-link text-lg font-semibold' : 'fluid-title-link text-xl font-semibold'}>
				{title}
			</h3>
		</a>
		<div class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-P-subtle">
			<FormattedDate date={publishedAt} />
			<span aria-hidden="true">·</span>
			<span>{getReadTimeMinutes(post.body)} min read</span>
		</div>
		{description && <p class={compact ? 'mt-1 text-P-lead' : 'mt-2 text-P-lead'}>{description}</p>}
		{
			showTags && tags.length > 0 && (
				<div class="mt-3 flex flex-wrap gap-2">
					{tags.map((tag) => (
						<Badge content={tag} href={getTagHref(tag)} />
					))}
				</div>
			)
		}
	</div>
</article>
