---
import { Search, X } from '@lucide/astro'
---

<div
	id="search-overlay"
	class="pointer-events-none fixed inset-0 z-50 flex items-start justify-center bg-P-bg/80 px-4 pt-20 opacity-0 backdrop-blur-sm transition-opacity sm:pt-28"
	aria-hidden="true"
>
	<div
		id="search-dialog"
		class="w-full max-w-2xl scale-95 overflow-hidden rounded-md border border-P-border bg-P-card shadow-2xl transition-transform"
		role="dialog"
		aria-modal="true"
		aria-label="Search"
	>
		<div class="flex items-center gap-3 border-b border-P-border px-4 py-3">
			<Search class="size-5 text-P-subtle" aria-hidden="true" />
			<input
				id="search-input"
				type="search"
				class="min-w-0 flex-1 bg-transparent text-base text-P-fg outline-none placeholder:text-P-subtle"
				placeholder="Search posts and skills..."
				autocomplete="off"
			/>
			<button
				id="search-close"
				type="button"
				class="inline-flex size-8 items-center justify-center rounded-sm text-P-subtle transition-colors hover:bg-P-muted hover:text-P-fg"
				aria-label="Close search"
			>
				<X class="size-5" aria-hidden="true" />
			</button>
		</div>
		<div id="search-results" class="max-h-[60vh] overflow-y-auto p-2"></div>
		<p id="search-status" class="px-4 py-10 text-center text-sm text-P-subtle">Type to start searching.</p>
	</div>
</div>

<script>
	type SearchItem = {
		source: 'blog' | 'skills'
		type: string
		title: string
		description: string
		tags: string[]
		href: string
		thumbnail?: string | undefined
		thumbnailAlt?: string | undefined
		publishedAt?: string
		readTime?: number
	}

	let searchItems: SearchItem[] | undefined

	const getSearchElements = () => ({
		overlay: document.getElementById('search-overlay'),
		dialog: document.getElementById('search-dialog'),
		input: document.getElementById('search-input') as HTMLInputElement | null,
		results: document.getElementById('search-results'),
		status: document.getElementById('search-status'),
	})

	const renderResults = (query: string) => {
		const { results, status } = getSearchElements()
		if (!results || !status) return

		const normalizedQuery = query.trim().toLowerCase()
		results.innerHTML = ''

		if (!normalizedQuery) {
			status.textContent = 'Type to start searching.'
			status.classList.remove('hidden')
			return
		}

		const matches = (searchItems ?? []).filter((item) => {
			const haystack = [item.title, item.description, item.publishedAt, item.source, item.type, ...item.tags]
				.join(' ')
				.toLowerCase()
			return haystack.includes(normalizedQuery)
		})

		if (matches.length === 0) {
			status.textContent = 'No results found.'
			status.classList.remove('hidden')
			return
		}

		status.classList.add('hidden')
		results.innerHTML = matches
			.map((item) => {
				const meta =
					item.source === 'blog'
						? `${item.readTime ?? 1} min read · ${item.publishedAt ?? ''}`
						: `Skills · ${item.type}`
				const thumbnail = item.thumbnail
					? `<img src="${item.thumbnail}" alt="${item.thumbnailAlt ?? ''}" class="h-16 w-24 rounded-sm object-cover" loading="lazy" />`
					: ''

				return `
					<a href="${item.href}" class="flex gap-3 rounded-sm px-3 py-3 no-underline transition-colors hover:bg-P-muted">
						${thumbnail}
						<span class="min-w-0">
							<span class="block text-base font-semibold text-P-link">${item.title}</span>
							<span class="mt-1 block text-sm text-P-subtle">${meta}</span>
							${item.description ? `<span class="mt-1 block text-sm text-P-lead">${item.description}</span>` : ''}
						</span>
					</a>
				`
			})
			.join('')
	}

	const openSearch = async () => {
		const { overlay, dialog, input } = getSearchElements()
		if (!overlay || !dialog || !input) return

		overlay.classList.remove('pointer-events-none', 'opacity-0')
		overlay.classList.add('opacity-100')
		overlay.setAttribute('aria-hidden', 'false')
		dialog.classList.remove('scale-95')
		dialog.classList.add('scale-100')
		document.body.style.overflow = 'hidden'
		window.setTimeout(() => input.focus(), 50)

		if (!searchItems) {
			const response = await fetch('/search.json')
			searchItems = await response.json()
		}

		renderResults(input.value)
	}

	const closeSearch = () => {
		const { overlay, dialog } = getSearchElements()
		if (!overlay || !dialog) return

		overlay.classList.add('pointer-events-none', 'opacity-0')
		overlay.classList.remove('opacity-100')
		overlay.setAttribute('aria-hidden', 'true')
		dialog.classList.add('scale-95')
		dialog.classList.remove('scale-100')
		document.body.style.overflow = ''
	}

	document.addEventListener('click', (event) => {
		const target = event.target instanceof Element ? event.target : null
		if (!target) return

		if (target.closest('[data-search-open]')) {
			void openSearch()
			return
		}

		if (target.closest('#search-close')) {
			closeSearch()
			return
		}

		const { overlay } = getSearchElements()
		if (event.target === overlay) closeSearch()
	})

	document.addEventListener('input', (event) => {
		if (event.target instanceof HTMLInputElement && event.target.id === 'search-input') {
			renderResults(event.target.value)
		}
	})

	document.addEventListener('keydown', (event) => {
		if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
			event.preventDefault()
			void openSearch()
		}

		if (event.key === 'Escape') closeSearch()
	})
</script>
