---
interface Props {
	content: string
	href?: string
}

const { content, href } = Astro.props
---

{
	href ? (
		<a
			href={href}
			class="inline-flex rounded-full bg-P-muted px-3 py-1 text-sm font-medium text-P-muted-fg no-underline transition-colors hover:bg-P-accent hover:text-P-link"
		>
			{content}
		</a>
	) : (
		<span class="inline-flex rounded-full bg-P-muted px-3 py-1 text-sm font-medium text-P-muted-fg">{content}</span>
	)
}
