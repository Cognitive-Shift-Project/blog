---
import { Info, TriangleAlert, Lightbulb, Flame } from '@lucide/astro'

const { type = 'note', title } = Astro.props

const calloutTypes = {
	note: {
		icon: Info,
		color: 'bg-P-card text-P-lead border-P-link',
		iconColor: 'text-P-link',
		defaultTitle: 'Note',
	},
	warning: {
		icon: TriangleAlert,
		color: 'bg-P-card text-P-lead border-P-border',
		iconColor: 'text-P-link',
		defaultTitle: 'Warning',
	},
	tip: {
		icon: Lightbulb,
		color: 'bg-P-card text-P-lead border-P-link',
		iconColor: 'text-P-link',
		defaultTitle: 'Tip',
	},
	danger: {
		icon: Flame,
		color: 'bg-P-card text-P-lead border-P-border',
		iconColor: 'text-P-link',
		defaultTitle: 'Danger',
	},
}

const current = calloutTypes[type as keyof typeof calloutTypes] || calloutTypes.note
const Icon = current.icon
---

<div class={`my-6 border-l-4 rounded-r-md p-5 shadow-sm ${current.color}`}>
	<div class="flex items-center gap-2 mb-2 font-bold">
		<div class={`shrink-0 ${current.iconColor}`}>
			<Icon size={20} />
		</div>
		<div>{title || current.defaultTitle}</div>
	</div>
	<div class="text-sm prose prose-sm max-w-none [&>*:first-child]:mt-0 [&>*:last-child]:mb-0 sm:pl-7">
		<slot />
	</div>
</div>
