---
import { Link } from '@lucide/astro'

export interface Props {
	href: string
	title: string
	description?: string
	domain?: string
}

const { href, title, description, domain } = Astro.props
const displayDomain = domain || new URL(href).hostname
---

<a href={href} target="_blank" rel="noopener noreferrer" class="my-8 block no-underline group">
	<div
		class="flex items-center overflow-hidden rounded-lg border border-P-border bg-P-card shadow-sm transition-colors hover:bg-P-muted hover:border-P-ring"
	>
		<div class="flex-1 p-4 sm:p-5">
			<div
				class="font-semibold text-P-heading mb-1 group-hover:text-P-link transition-colors line-clamp-1"
			>
				{title}
			</div>
			{
				description && (
					<div class="text-sm text-P-lead mb-3 line-clamp-2 leading-relaxed">
						{description}
					</div>
				)
			}
			<div class="text-xs font-medium text-P-subtle flex items-center gap-1.5 mt-auto">
				<Link size={12} />
				{displayDomain}
			</div>
		</div>
	</div>
</a>
