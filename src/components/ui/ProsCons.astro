---
import { CircleCheckBig, CircleX } from '@lucide/astro'

export interface Props {
	pros: string[]
	cons: string[]
}

const { pros = [], cons = [] } = Astro.props
---

<div class="my-8 grid gap-4 grid-cols-1 md:grid-cols-2 text-sm w-full">
	<div
		class="rounded-md border border-P-border bg-P-card p-5"
	>
		<div class="font-semibold flex items-center gap-2 text-P-link mb-4">
			<CircleCheckBig size={18} />
			<span>Pros</span>
		</div>
		<ul class="space-y-2 m-0 p-0 list-none">
			{
				pros.map((pro) => (
					<li class="flex items-start gap-2 text-P-lead">
						<span class="text-P-link shrink-0 mt-0.5">•</span>
						<span>{pro}</span>
					</li>
				))
			}
		</ul>
	</div>

	<div class="rounded-md border border-P-border bg-P-card p-5">
		<div class="font-semibold flex items-center gap-2 text-P-link mb-4">
			<CircleX size={18} />
			<span>Cons</span>
		</div>
		<ul class="space-y-2 m-0 p-0 list-none">
			{
				cons.map((con) => (
					<li class="flex items-start gap-2 text-P-lead">
						<span class="text-P-link shrink-0 mt-0.5">•</span>
						<span>{con}</span>
					</li>
				))
			}
		</ul>
	</div>
</div>
