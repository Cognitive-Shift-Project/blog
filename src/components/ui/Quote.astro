---
import { Quote as QuoteIcon } from '@lucide/astro'

const { author, title } = Astro.props
---

<figure
	class="my-8 rounded-md bg-P-card p-6 sm:p-8 flex items-start gap-4 border border-P-border shadow-sm"
>
	<div class="text-P-link flex-shrink-0 pt-1">
		<QuoteIcon size={32} />
	</div>
	<div class="flex-1 w-0">
		<blockquote class="text-lg/relaxed font-medium italic text-P-heading m-0 p-0 border-0">
			<slot />
		</blockquote>
		{
			(author || title) && (
				<figcaption class="mt-4 flex items-center gap-2">
					{author && <span class="font-semibold text-P-heading">{author}</span>}
					{author && title && <span class="text-P-subtle">—</span>}
					{title && <span class="text-sm text-P-subtle">{title}</span>}
				</figcaption>
			)
		}
	</div>
</figure>
