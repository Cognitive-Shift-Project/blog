---
import { type CollectionEntry, render } from 'astro:content'
import Layout from '@/layouts/Layout.astro'
import FormattedDate from '@/components/FormattedDate.astro'
import ShareButtons from '@/components/blog/ShareButtons.astro'
import TableOfContents from '@/components/blog/TableOfContents.astro'
import Badge from '@/components/ui/Badge.astro'
import PostPreview from '@/components/blog/PostPreview.astro'
import { getBlogPostHref, getPublishedBlogPosts, getReadTimeMinutes, getRelatedPosts, getTagHref } from '@/lib/blog'

type Props = { post: CollectionEntry<'blog'> }

export async function getStaticPaths() {
	const posts = await getPublishedBlogPosts()

	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}))
}

const { post } = Astro.props
const { title, description, publishedAt, updatedAt, tags, thumbnail, thumbnailAlt } = post.data

const { Content, headings } = await render(post)
const posts = await getPublishedBlogPosts()
const currentIndex = posts.findIndex((candidate) => candidate.id === post.id)
const newerPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined
const olderPost = currentIndex >= 0 && currentIndex < posts.length - 1 ? posts[currentIndex + 1] : undefined
const relatedPosts = getRelatedPosts(post, posts)
const readTime = getReadTimeMinutes(post.body)
const postUrl = new URL(getBlogPostHref(post), Astro.site ?? Astro.url).toString()
---

<Layout
	variant="full"
	meta={{
		type: 'blog',
		title,
		description,
		publishedAt,
		ogImageUrl: new URL(`/blog/${post.id}/og.png`, Astro.site ?? Astro.url).toString(),
	}}
>
	<div class="fixed inset-x-0 top-0 z-50 h-1 bg-transparent">
		<div id="reading-progress" class="h-full w-0 bg-P-link transition-[width] duration-150"></div>
	</div>
	<div class="mx-auto w-full max-w-(--layout-max-width) px-4 py-8 sm:py-12 md:py-16">
		<a class="mb-8 inline-block text-sm font-semibold text-P-link no-underline hover:text-P-link-hover" href="/blog/">
			Back to blog
		</a>
		<header class="mb-12 max-w-prose">
			<h1 class="text-h1 text-P-heading text-balance mb-4">{title}</h1>
			{description && <p class="text-lead text-P-lead text-pretty mb-4">{description}</p>}
			<div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-base text-P-subtle">
				<FormattedDate date={publishedAt} />
				{
					updatedAt && (
						<>
							<span aria-hidden="true">·</span>
							<FormattedDate date={updatedAt} prefix="Updated " />
						</>
					)
				}
				<span aria-hidden="true">·</span>
				<span>{readTime} min read</span>
			</div>
			{
				tags.length > 0 && (
					<div class="mt-4 flex flex-wrap gap-2">
						{tags.map((tag) => (
							<Badge content={tag} href={getTagHref(tag)} />
						))}
					</div>
				)
			}
			<div class="mt-6">
				<ShareButtons url={postUrl} title={title} />
			</div>
			{
				thumbnail && (
					<img
						src={thumbnail}
						alt={thumbnailAlt ?? ''}
						class="mt-8 aspect-video w-full rounded-md border border-P-border object-cover"
						loading="eager"
						decoding="async"
					/>
				)
			}
		</header>
		<div class="flex items-start gap-12">
			<article class="prose min-w-0 flex-1">
				<Content />
			</article>
			<TableOfContents headings={headings} />
		</div>
		<footer class="not-prose mt-16 max-w-prose border-t border-P-border pt-8">
			<div>
				<h2 class="mb-4 text-tiny uppercase text-P-subtle">Share this post</h2>
				<ShareButtons url={postUrl} title={title} />
			</div>
			{
				relatedPosts.length > 0 && (
					<section class="mt-12">
						<h2 class="mb-4 text-tiny uppercase text-P-subtle">Related posts</h2>
						<ul class="space-y-4">
							{relatedPosts.map((relatedPost) => (
								<li>
									<PostPreview post={relatedPost} compact showTags={false} />
								</li>
							))}
						</ul>
					</section>
				)
			}
			<nav class="mt-12 grid gap-4 border-t border-P-border pt-8 sm:grid-cols-2" aria-label="Post navigation">
				<div>
					{
						olderPost && (
							<a class="group block no-underline" href={getBlogPostHref(olderPost)}>
								<span class="text-sm text-P-subtle">Older</span>
								<span class="mt-1 block font-semibold text-P-link group-hover:text-P-link-hover">
									{olderPost.data.title}
								</span>
							</a>
						)
					}
				</div>
				<div class="sm:text-right">
					{
						newerPost && (
							<a class="group block no-underline" href={getBlogPostHref(newerPost)}>
								<span class="text-sm text-P-subtle">Newer</span>
								<span class="mt-1 block font-semibold text-P-link group-hover:text-P-link-hover">
									{newerPost.data.title}
								</span>
							</a>
						)
					}
				</div>
			</nav>
		</footer>
	</div>
	<script>
		const progress = document.getElementById('reading-progress')

		const updateProgress = () => {
			if (!progress) return

			const scrollTop = document.documentElement.scrollTop || document.body.scrollTop
			const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight
			const percent = scrollHeight <= 0 ? 100 : (scrollTop / scrollHeight) * 100
			progress.style.width = `${percent}%`
		}

		updateProgress()
		window.addEventListener('scroll', updateProgress, { passive: true })
	</script>
</Layout>
