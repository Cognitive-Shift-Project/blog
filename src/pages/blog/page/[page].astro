---
import type { GetStaticPaths } from 'astro'

import Layout from '@/layouts/Layout.astro'
import PostPreview from '@/components/blog/PostPreview.astro'
import {
	BLOG_POSTS_PER_PAGE,
	getPublishedBlogPosts,
	groupPostsByMonth,
} from '@/lib/blog'

type Props = {
	page: number
	totalPages: number
}

export const getStaticPaths = (async () => {
	const posts = await getPublishedBlogPosts()
	const totalPages = Math.ceil(posts.length / BLOG_POSTS_PER_PAGE)

	return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
		const page = index + 2
		return {
			params: { page: String(page) },
			props: { page, totalPages },
		}
	})
}) satisfies GetStaticPaths

const { page, totalPages } = Astro.props as Props
const allPosts = await getPublishedBlogPosts()
const posts = allPosts.slice((page - 1) * BLOG_POSTS_PER_PAGE, page * BLOG_POSTS_PER_PAGE)
const groupedPosts = groupPostsByMonth(posts)
---

<Layout
	meta={{
		type: 'page',
		title: `Blog - Page ${page}`,
		description: 'Analyses, paper reviews, and experiment logs from the Cognitive Shift Project collective.',
	}}
>
	<section>
		<hgroup class="mb-8 sm:mb-12">
			<a class="mb-6 inline-block text-sm font-semibold text-P-link no-underline hover:text-P-link-hover" href="/blog/">
				Back to blog
			</a>
			<h1 class="text-h1 text-P-heading text-balance mb-4">Blog</h1>
			<div class="text-lead text-P-lead text-pretty">
				<p>Page {page} of {totalPages}</p>
			</div>
		</hgroup>
		<div class="space-y-12">
			{
				groupedPosts.map(({ period, posts: periodPosts }) => (
					<section>
						<h2 class="mb-4 border-b border-P-border pb-2 text-h3 text-P-heading">{period}</h2>
						<ul class="space-y-6">
						{periodPosts.map((post) => (
							<li>
								<PostPreview post={post} />
							</li>
						))}
						</ul>
					</section>
				))
			}
		</div>
		<nav class="mt-12 flex justify-center gap-2" aria-label="Blog pagination">
			{
				Array.from({ length: totalPages }, (_, index) => index + 1).map((pageNumber) =>
					pageNumber === page ? (
						<span class="rounded-sm bg-P-link px-3 py-2 text-sm font-semibold text-P-bg" aria-current="page">
							{pageNumber}
						</span>
					) : (
						<a
							href={pageNumber === 1 ? '/blog/' : `/blog/page/${pageNumber}/`}
							class="rounded-sm px-3 py-2 text-sm font-semibold text-P-link no-underline transition-colors hover:bg-P-muted hover:text-P-link-hover"
						>
							{pageNumber}
						</a>
					),
				)
			}
		</nav>
	</section>
</Layout>
