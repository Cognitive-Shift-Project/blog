---
import type { GetStaticPaths } from 'astro'

import Layout from '@/layouts/Layout.astro'
import FormattedDate from '@/components/FormattedDate.astro'
import Badge from '@/components/ui/Badge.astro'
import { getBlogPostHref, getPublishedBlogPosts, getReadTimeMinutes, getTagCounts, getTagHref } from '@/lib/blog'
import { cn } from '@/lib/style'

type Props = {
	tag: string
}

export const getStaticPaths = (async () => {
	const posts = await getPublishedBlogPosts()

	return getTagCounts(posts).map(({ tag }) => ({
		params: { tag },
		props: { tag },
	}))
}) satisfies GetStaticPaths

const { tag } = Astro.props as Props
const posts = (await getPublishedBlogPosts()).filter((post) => post.data.tags.includes(tag))
---

<Layout
	meta={{
		type: 'page',
		title: `Posts tagged ${tag}`,
		description: `${posts.length} Cognitive Shift Project posts tagged ${tag}.`,
	}}
>
	<section>
		<hgroup class="mb-8 sm:mb-12">
			<a class="mb-6 inline-block text-sm font-semibold text-P-link no-underline hover:text-P-link-hover" href="/tags/">
				All tags
			</a>
			<h1 class="text-h1 text-P-heading text-balance mb-4">#{tag}</h1>
			<div class="text-lead text-P-lead text-pretty">
				<p>{posts.length} {posts.length === 1 ? 'post' : 'posts'} tagged with {tag}.</p>
			</div>
		</hgroup>
		<ul class="space-y-6">
			{
				posts.map((post) => (
					<li>
						<a href={getBlogPostHref(post)} class="group block">
							<h2
								class={cn(
									'text-xl font-semibold transition-[color,text-decoration-thickness]',
									'underline underline-offset-2 decoration-current decoration-1 hover:decoration-[1.5px]',
									'text-P-link group-hover:text-P-link-hover',
								)}
							>
								{post.data.title}
							</h2>
						</a>
						<div class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-P-subtle">
							<FormattedDate date={post.data.publishedAt} />
							<span aria-hidden="true">·</span>
							<span>{getReadTimeMinutes(post.body)} min read</span>
						</div>
						{post.data.description && <p class="mt-2 text-P-lead">{post.data.description}</p>}
						<div class="mt-3 flex flex-wrap gap-2">
							{post.data.tags.map((postTag) => (
								<Badge content={postTag} href={getTagHref(postTag)} />
							))}
						</div>
					</li>
				))
			}
		</ul>
	</section>
</Layout>
