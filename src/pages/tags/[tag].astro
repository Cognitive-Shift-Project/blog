---
import type { GetStaticPaths } from 'astro'

import Layout from '@/layouts/Layout.astro'
import PostPreview from '@/components/blog/PostPreview.astro'
import Badge from '@/components/ui/Badge.astro'
import { getTaggedContent, getUnifiedTagCounts, getUnifiedTagHref } from '@/lib/tags'

type Props = {
	tag: string
}

export const getStaticPaths = (async () => {
	return (await getUnifiedTagCounts()).map(({ tag }) => ({
		params: { tag },
		props: { tag },
	}))
}) satisfies GetStaticPaths

const { tag } = Astro.props as Props
const { posts, skills } = await getTaggedContent(tag)
const total = posts.length + skills.length
---

<Layout
	meta={{
		type: 'page',
		title: `Content tagged ${tag}`,
		description: `${total} Cognitive Shift Project items tagged ${tag}.`,
	}}
>
	<section>
		<hgroup class="mb-8 sm:mb-12">
			<a class="mb-6 inline-block text-sm font-semibold text-P-link no-underline hover:text-P-link-hover" href="/tags/">
				All tags
			</a>
			<h1 class="text-h1 text-P-heading text-balance mb-4">#{tag}</h1>
			<div class="text-lead text-P-lead text-pretty">
				<p>{total} {total === 1 ? 'item' : 'items'} tagged with {tag}.</p>
			</div>
		</hgroup>
		<div class="space-y-10">
			{
				posts.length > 0 && (
					<section>
						<h2 class="mb-4 text-h3 text-P-heading">Blog</h2>
						<ul class="space-y-6">
							{posts.map(({ post }) => (
								<li class="rounded-md border border-P-border bg-P-card p-4">
									<PostPreview post={post} />
								</li>
							))}
						</ul>
					</section>
				)
			}
			{
				skills.length > 0 && (
					<section>
						<h2 class="mb-4 text-h3 text-P-heading">Skills</h2>
						<ul class="space-y-4">
							{skills.map(({ item, href }) => (
								<li class="rounded-md border border-P-border bg-P-card p-4">
									<a href={href} class="group block no-underline">
										<div class="flex items-start gap-4">
											<img
												src={item.coverPreviewPath}
												alt=""
												class="h-20 w-32 rounded-sm object-cover"
												loading="lazy"
												decoding="async"
											/>
											<div class="min-w-0">
												<h3 class="text-xl font-semibold text-P-link group-hover:text-P-link-hover">{item.name}</h3>
												<p class="mt-1 text-sm text-P-subtle">Skills · {item.type}</p>
												<p class="mt-2 text-P-lead">{item.description}</p>
											</div>
										</div>
									</a>
									<div class="mt-3 flex flex-wrap gap-2">
										{[item.category, ...item.keywords].map((skillTag) => (
											<Badge content={skillTag} href={getUnifiedTagHref(skillTag)} />
										))}
									</div>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</div>
	</section>
</Layout>
